{
    "elements": [
        {
            "type": "ValidationTextBox",
            "name": "Host",
            "caption": "IP-Adresse / Hostname"
        },
        {
            "type": "PasswordTextBox",
            "name": "APIKey",
            "caption": "API-Key"
        },
        {
            "type": "ValidationTextBox",
            "name": "DeviceGuid",
            "caption": "Device-GUID"
        },
        {
            "type": "NumberSpinner",
            "name": "UpdateInterval",
            "caption": "Aktualisierungsintervall (Sekunden, 0 = aus)",
            "minimum": 0,
            "maximum": 86400
        },
        {
            "type": "Label",
            "caption": "Impuls-/Tastermodus (z. B. Garagentor / Türöffner): Beim Einschalten geht das Relais an und nach der Impulsdauer automatisch wieder aus."
        },
        {
            "type": "CheckBox",
            "name": "PulseMode",
            "caption": "Impuls-/Tastermodus aktivieren"
        },
        {
            "type": "NumberSpinner",
            "name": "PulseDuration",
            "caption": "Impulsdauer (ms)",
            "minimum": 200,
            "maximum": 60000,
            "suffix": "ms"
        },
        {
            "type": "Label",
            "caption": "Visualisierung (eigene Kachel)"
        },
        {
            "type": "Select",
            "name": "VisuStyle",
            "caption": "Kachel-Stil",
            "options": [
                { "caption": "Automatisch (Gartentor bei Impuls, sonst Außenleuchte)", "value": "auto" },
                { "caption": "Außenleuchte", "value": "lamp" },
                { "caption": "Gartentor (animiert)", "value": "gate" },
                { "caption": "Power-Schalter (mit Watt)", "value": "power" },
                { "caption": "Keine eigene Kachel", "value": "none" }
            ]
        },
        {
            "type": "Select",
            "name": "VisuTheme",
            "caption": "Kachel-Design",
            "options": [
                { "caption": "Automatisch (System)", "value": "auto" },
                { "caption": "Hell", "value": "light" },
                { "caption": "Dunkel", "value": "dark" }
            ]
        }
    ],
    "actions": [
        {
            "type": "Button",
            "caption": "Jetzt aktualisieren",
            "onClick": "ELTAKOIPSW_Update($id);"
        },
        {
            "type": "Button",
            "caption": "Impuls auslösen (Öffnen)",
            "onClick": "ELTAKOIPSW_Pulse($id);"
        },
        {
            "type": "Button",
            "caption": "Einschalten",
            "onClick": "ELTAKOIPSW_SetState($id, true);"
        },
        {
            "type": "Button",
            "caption": "Ausschalten",
            "onClick": "ELTAKOIPSW_SetState($id, false);"
        }
    ],
    "status": [
        {
            "code": 102,
            "icon": "active",
            "caption": "Aktiv"
        },
        {
            "code": 104,
            "icon": "inactive",
            "caption": "Nicht konfiguriert (Host, API-Key und Device-GUID erforderlich)"
        },
        {
            "code": 201,
            "icon": "error",
            "caption": "Gerät nicht erreichbar oder Anmeldung fehlgeschlagen"
        }
    ]
}
